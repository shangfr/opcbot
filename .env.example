# ============================================================
# OPCBot 环境变量配置
# ============================================================

# === 必需 ===

# NextAuth JWT 签名密钥
# 生成方式: openssl rand -base64 32
AUTH_SECRET=****

# PostgreSQL 数据库连接字符串 (pooler 模式，日常查询用)
POSTGRES_URL=postgresql://user:password@host/dbname?sslmode=require

# PostgreSQL 直连 URL（不含 -pooler），用于数据库迁移等 DDL 操作
POSTGRES_URL_NON_POOLING=postgresql://user:password@host/dbname?sslmode=require

# === AI 模型 API Key ===

# 智谱 AI (zhipuai)
ZHIPU_API_KEY=****
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# DeepSeek
DEEPSEEK_API_KEY=****

# === 管理 ===

# 管理员邮箱（逗号分隔）
# 注意：此配置仅用于初始化管理员，用户注册后需运行 scripts/sync-admin-roles.ts 同步到数据库
# 或者直接通过用户管理页面设置角色为 admin
ADMIN_EMAILS=your@email.com

# === 可选 ===

# Vercel Blob 存储（文件上传，仅 Vercel 部署需要）
# 非 Vercel 部署需替换为 S3/R2 等兼容存储
BLOB_READ_WRITE_TOKEN=****

# Redis 缓存（IP 限流等，不配置则跳过限流）
# REDIS_URL=redis://localhost:6379

# 站点公开 URL（用于 SEO metadataBase，默认 http://localhost:3000）
# NEXT_PUBLIC_BASE_URL=https://your-domain.com

# Vercel AI Gateway（仅非 Vercel 部署需要）
# AI_GATEWAY_API_KEY=****
